# Life OS Environment Configuration
# Copy this file to .env.local and fill in your values

# API Configuration
# For local development: http://localhost:8000/api
# For production: https://your-api-domain.com/api
REACT_APP_API_URL=http://localhost:8000/api

# Google Sheets Configuration
# Get these from Google Cloud Console
REACT_APP_GOOGLE_SHEETS_API_KEY=your_google_sheets_api_key_here
REACT_APP_GOOGLE_SHEETS_ID=your_google_sheets_id_here

# Feature Flags
# Set to 'true' to enable Google Sheets backend
REACT_APP_USE_GOOGLE_SHEETS=false

# Debug Mode
# Set to 'true' to enable debug logging
REACT_APP_DEBUG=false
