# Google Sheets Integration - Environment Variables
# Copy this file to .env.local and fill in your actual values

# Google Sheets Spreadsheet ID
# Get this from your Google Sheet URL: https://docs.google.com/spreadsheets/d/{SHEET_ID}/edit
VITE_GOOGLE_SHEET_ID=your-spreadsheet-id-here

# Google OAuth 2.0 Client ID
# Create this in Google Cloud Console: https://console.cloud.google.com/
# 1. Create a new project
# 2. Enable Google Sheets API
# 3. Create OAuth 2.0 credentials (Web application)
# 4. Add authorized redirect URIs (your Vercel domain + http://localhost:3000 for local dev)
# 5. Copy the Client ID here
VITE_GOOGLE_CLIENT_ID=your-client-id-here.apps.googleusercontent.com

# Optional: API Base URL (defaults to http://localhost:8000/api for local dev)
# VITE_API_BASE_URL=http://localhost:8000/api
