{
  "version": 2,
  "buildCommand": "echo 'No build needed for static SPA'",
  "outputDirectory": "src",
  "public": true,
  "functions": {
    "api/sheets.js": {
      "memory": 1024,
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/sheets.js"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/index.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600"
        }
      ]
    }
  ],
  "env": {
    "VITE_GOOGLE_SHEET_ID": "@vite_google_sheet_id",
    "GOOGLE_SERVICE_ACCOUNT_KEY": "@google_service_account_key"
  }
}

